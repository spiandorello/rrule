{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist/esm",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "importHelpers": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["./src/**/*"],
  "exclude": ["node_modules", "./test/**/*"]
}

{
  "name": "@spiandorello/rrulejs",
  "version": "2.9.0",
  "description": "Hardened fork of rrule — JavaScript library for working with recurrence rules for calendar dates. DoS-resistant parser, iteration guards, and a typed Recurrence API with inclusive-day UNTIL semantics.",
  "homepage": "https://github.com/spiandorello/rrule#readme",
  "license": "BSD-3-Clause",
  "keywords": [
    "dates",
    "recurrences",
    "calendar",
    "icalendar",
    "rfc",
    "rfc5545",
    "rrule",
    "typescript",
    "typed"
  ],
  "author": "Eduardo da Veiga Spiandorello <eduardo.spiandorello@gmail.com>",
  "contributors": [
    "Jakub Roztocil",
    "Lars Schöning",
    "David Golightly"
  ],
  "type": "commonjs",
  "main": "dist/es5/rrule.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/es5/rrule.js"
      }
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spiandorello/rrule.git"
  },
  "bugs": {
    "url": "https://github.com/spiandorello/rrule/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "yarn clean",
    "prepublishOnly": "yarn build",
    "build": "yarn lint && yarn format-check && tsc -b tsconfig.build.json && webpack && node scripts/fix-esm-extensions.mjs",
    "clean": "rm -rf dist/",
    "lint": "yarn eslint .",
    "lint:fix": "yarn eslint . --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "format": "yarn prettier --write .",
    "format-check": "yarn prettier --check .",
    "test": "jest **/*.test.ts",
    "test-ci": "jest --coverage **/*.test.ts"
  },
  "lint-staged": {
    "*.ts": [
      "yarn lint:fix",
      "yarn format"
    ]
  },
  "devDependencies": {
    "@codecov/webpack-plugin": "^2.0.1",
    "@eslint/js": "^10.0.1",
    "@types/assert": "^1.5.11",
    "@types/jest": "^30.0.0",
    "@types/node": "^17.0.45",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.59.3",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "jest-junit": "^17.0.0",
    "lint-staged": "^13.3.0",
    "mockdate": "^3.0.5",
    "prettier": "^3.8.3",
    "source-map-loader": "^5.0.0",
    "source-map-support": "^0.5.16",
    "terser-webpack-plugin": "^5.6.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "unminified-webpack-plugin": "^3.0.0",
    "webpack": "^5.94.0",
    "webpack-cli": "^7.0.2"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {},
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "resolutions": {
    "@babel/helpers": "^7.26.10",
    "@babel/traverse": "^7.23.2",
    "@istanbuljs/load-nyc-config/js-yaml": "^3.14.2",
    "braces": "^3.0.3",
    "cross-spawn": "^7.0.5",
    "debug": "^4.4.3",
    "flatted": "^3.4.2",
    "js-yaml": "^4.1.1",
    "json5": "^2.2.2",
    "kind-of": "^6.0.3",
    "micromatch": "^4.0.8",
    "minimist": "^1.2.6",
    "picomatch": "^2.3.2",
    "semver": "^7.5.2",
    "serialize-javascript": "^7.0.3",
    "terser": "^5.14.2",
    "word-wrap": "^1.2.5",
    "yaml": "^2.2.2"
  }
}
